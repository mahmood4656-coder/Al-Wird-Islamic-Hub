<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window as soon as the process has started.
         This theme determines the app's splash screen. -->
    <style name="LaunchTheme" parent="android:Theme.Light.NoTitleBar">
        <!-- Show a splash image on the launching Activity -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Theme applied to the Android Window as soon as the Flutter Experience has been initialized -->
    <style name="NormalTheme" parent="android:Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
